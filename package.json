{
  "name": "evade-player",
  "description": "React/Web Component video player powered by Video.js — HLS, accessible controls, audio processing, content navigation, and fragment skip support",
  "private": false,
  "version": "0.1.3",
  "type": "module",
  "license": "MIT",
  "author": "leo-need-more-coffee",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leo-need-more-coffee/evade-player.git"
  },
  "homepage": "https://github.com/leo-need-more-coffee/evade-player#readme",
  "bugs": {
    "url": "https://github.com/leo-need-more-coffee/evade-player/issues"
  },
  "keywords": [
    "video",
    "player",
    "videojs",
    "react",
    "web-component",
    "hls",
    "streaming",
    "accessible",
    "anime"
  ],
  "main": "./dist/player-platform.js",
  "module": "./dist/player-platform.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/player-platform.js",
      "default": "./dist/player-platform.js"
    },
    "./skins/default/skin.css": "./dist/player-platform.css"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "build:standalone": "vite build --config vite.config.standalone.ts",
    "build:standalone:thin": "vite build --config vite.config.standalone-thin.ts",
    "build:standalone:all": "npm run build:standalone && npm run build:standalone:thin",
    "build:all": "npm run build && npm run build:standalone:all",
    "lint": "eslint .",
    "prepublishOnly": "npm run build:all"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@videojs/react": "^10.0.0-beta.24",
    "lucide-react": "^1.16.0"
  },
  "devDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "@videojs/react": "^10.0.0-beta.24",
    "lucide-react": "^1.16.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.1"
  }
}
